# Auth
GANG_JWT_SECRET=replace-with-a-long-random-secret

# Database
GANG_DATABASE_URL=gang-chat.db

# Server
GANG_BIND=127.0.0.1:21116
GANG_TRUSTED_PROXIES=127.0.0.1,::1

# Assets
# Leave empty for auto: local when no COS config is present, COS when COS
# bucket/credentials are present. Set to local to force disk-only behavior.
GANG_STORAGE_BACKEND=
GANG_ASSET_DIR=assets
GANG_ASSET_OBJECT_PREFIX=assets
GANG_ASSET_PUBLIC_BASE_URL=
GANG_ASSET_CACHE_CONTROL=public, max-age=31536000, immutable
GANG_ASSET_UPLOAD_MAX_BYTES=52428800
GANG_IMAGE_UPLOAD_MAX_BYTES=10485760

# Tencent COS. Keep real values in an untracked .env/deploy secret store.
GANG_COS_BUCKET=
GANG_COS_REGION=
GANG_COS_BUCKET_URL=
GANG_COS_SECRET_ID=
GANG_COS_SECRET_KEY=
GANG_COS_SESSION_TOKEN=
GANG_COS_OBJECT_ACL=public-read

# Account activity location
# Download GeoLite2-City.mmdb from MaxMind and point this at the file.
GANG_GEOIP_DB_PATH=

# LiveKit
LIVEKIT_HOST=http://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# Room music box (server-side download/transcode/broadcast).
# Requires LiveKit above to be configured and ffmpeg/ffprobe on PATH.
GANG_FFMPEG_PATH=ffmpeg
GANG_MUSIC_BOX_DIR=music-box
# Per-room cap on transcoded audio on disk (bytes). Default 200 MiB.
GANG_MUSIC_BOX_MAX_BYTES_PER_ROOM=209715200
GANG_MUSIC_BOX_OPUS_BITRATE=128k
GANG_MUSIC_BOX_TRANSCODE_WORKERS=3
# GD Studio source + download quality (128/192/320/740/999).
GANG_MUSIC_BOX_SOURCE=netease
GANG_MUSIC_BOX_SOURCE_BITRATE=192
